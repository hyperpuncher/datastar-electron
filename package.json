{
	"name": "datastar-electron",
	"version": "1.0.0",
	"description": "Datastar in Electron - no more IPC",
	"keywords": [
		"datastar",
		"electron",
		"server-sent-events",
		"sse",
		"ssr"
	],
	"license": "MIT",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "tsgo",
		"prepublishOnly": "bun run build",
		"clean": "rm -rf dist",
		"fmt": "bunx oxfmt",
		"lint": "bunx oxlint",
		"example": "bunx electron examples/demo.ts"
	},
	"dependencies": {
		"@starfederation/datastar-sdk": "^1.0.0"
	},
	"files": ["dist"],
	"devDependencies": {
		"@typescript/native-preview": "^7.0.0-dev.20260514.1",
		"electron": "^42.1.0"
	}
}
